{
  // Use IntelliSense to learn about possible attributes.
  // Hover to view descriptions of existing attributes.
  // For more information, visit: https://go.microsoft.com/fwlink/?linkid=830387
  "version": "0.2.0",
  "configurations": [
    {
      "type": "java",
      "name": "GoToBall (Desktop)",
      "request": "launch",
      "mainClass": "frc.robot.GoToBall",
      "projectName": "2026Rebuilt-ClickToPoint",
      "vmArgs": "-Djava.library.path=${workspaceFolder}/build/jni/release",
      "env": {
        "LD_LIBRARY_PATH": "${workspaceFolder}/build/jni/release:${env:LD_LIBRARY_PATH}"
      },
      "console": "internalConsole",
      "cwd": "${workspaceFolder}",
      "windows": {
        "env": {
          "PATH": "${workspaceFolder}\\build\\jni\\release;${env:PATH}"
        }
      }
    },
    {
      "type": "java",
      "name": "Main",
      "request": "launch",
      "mainClass": "frc.robot.Main",
      "projectName": "2026Rebuilt-ClickToPoint"
    },
    {
      "type": "wpilib",
      "name": "WPILib Desktop Debug",
      "request": "launch",
      "desktop": true
    },
    {
      "type": "wpilib",
      "name": "WPILib roboRIO Debug",
      "request": "launch",
      "desktop": false
    }
  ]
}
